{
    "version": "2.0.0",
    "tasks": [
      {
        "label": "Build",
        "type": "npm",
        "script": "build",
        "group": {
          "kind": "build",
          "isDefault": true
        },
        "problemMatcher": []
      },
      {
        "label": "Watch",
        "type": "npm",
        "script": "watch",
        "isBackground": true,
        "problemMatcher": []
      },
      {
        "label": "Serve",
        "type": "npm",
        "script": "serve",
        "isBackground": true,
        "problemMatcher": {
          "pattern": { "regexp": "." },
          "background": {
            "activeOnStart": true,
            "beginsPattern": ".",
            "endsPattern": "Accepting connections"
          }
        }
      },
      {
        "label": "Build & Serve",
        "dependsOn": ["Build", "Serve"],
        "dependsOrder": "sequence",
        "presentation": {
          "reveal": "silent"
        }
      }
    ]
  }
